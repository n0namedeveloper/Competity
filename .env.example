# ──────────────────────────────────────────────
# Competity — Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# ── Database ──
DATABASE_URL=postgresql+asyncpg://competity:competity@localhost:5432/competity

# ── DeepSeek AI ──
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Telegram ──
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── GitHub (optional, raises rate limit) ──
GITHUB_TOKEN=

# ── Reddit (optional) ──
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=competity-bot/0.1

# ── Product Hunt (optional) ──
PRODUCTHUNT_TOKEN=

# ── App ──
APP_ENV=development
LOG_LEVEL=INFO

# ── Scheduler ──
COLLECT_CRON_HOUR=3
COLLECT_CRON_MINUTE=0
REPORT_CRON_DAY_OF_WEEK=mon
REPORT_CRON_HOUR=9
REPORT_CRON_MINUTE=0
